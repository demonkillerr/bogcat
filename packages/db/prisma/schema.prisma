// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  username String  @unique // "coordinator" | "frontdesk" | "admin" | "optometrist_room1" .. "optometrist_room4"
  role     Role

  session Session?
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  COORDINATOR
  FRONTDESK
  ADMIN
  OPTOMETRIST
}

// ─── Colleagues ──────────────────────────────────────────────────────────────

model Colleague {
  id           String         @id @default(cuid())
  name         String         @unique
  type         ColleagueType
  isAssignable Boolean        @default(true) // false for Iqbal (main manager)

  colleagueOnDays ColleagueOnDay[]
  taskAllocations TaskAllocation[]
}

enum ColleagueType {
  OC
  SENIOR_OC
  MANAGER
}

// ─── Working Day ─────────────────────────────────────────────────────────────

model WorkingDay {
  id        String   @id @default(cuid())
  date      DateTime @unique
  locked    Boolean  @default(false) // true after 10AM

  colleagues      ColleagueOnDay[]
  taskAllocations TaskAllocation[]
  patientArrivals PatientArrival[]
  optometristCalls OptometristCall[]
}

model ColleagueOnDay {
  id             String    @id @default(cuid())
  workingDayId   String
  colleagueId    String
  onLunch        Boolean   @default(false)
  lunchStartedAt DateTime?

  workingDay WorkingDay @relation(fields: [workingDayId], references: [id])
  colleague  Colleague  @relation(fields: [colleagueId], references: [id])

  @@unique([workingDayId, colleagueId])
}

// ─── Task Allocation ─────────────────────────────────────────────────────────

model TaskAllocation {
  id            String           @id @default(cuid())
  workingDayId  String
  colleagueId   String
  taskType      TaskType
  status        AllocationStatus @default(ACTIVE)
  allocatedAt   DateTime         @default(now())
  durationMins  Int              // base duration in minutes
  extendedUntil DateTime?        // set when coordinator extends

  workingDay WorkingDay @relation(fields: [workingDayId], references: [id])
  colleague  Colleague  @relation(fields: [colleagueId], references: [id])
}

enum TaskType {
  PRE_SCREENING_FULL_SIGHT_TEST   // 15 mins
  PRE_SCREENING_SUPPLEMENTARY     // 10 mins
  POST_CHECKS                     // 10 mins
  DISPENSING_SINGLE_VISION        // 30 mins
  DISPENSING_VARIFOCALS           // 30 mins
  COLLECTION                      // 10 mins
  EGOS                            // 30 mins
  FILE_PULLING                    // 60 mins
  SCANNING                        // 60 mins
}

enum AllocationStatus {
  ACTIVE
  COMPLETED
  EXTENDED
}

// ─── Patient Arrivals ─────────────────────────────────────────────────────────

model PatientArrival {
  id           String        @id @default(cuid())
  workingDayId String
  name         String
  reason       ArrivalReason
  notes        String?
  arrivedAt    DateTime      @default(now())
  acknowledged Boolean       @default(false)

  workingDay WorkingDay @relation(fields: [workingDayId], references: [id])
}

enum ArrivalReason {
  SIGHT_TEST
  COLLECTION
  ADJUSTMENT
}

// ─── Optometrist ─────────────────────────────────────────────────────────────

model OptometristProfile {
  id         String   @id @default(cuid())
  date       DateTime
  name       String
  roomNumber Int
  locked     Boolean  @default(true) // locked immediately on creation

  @@unique([date, roomNumber])
}

model OptometristCall {
  id              String         @id @default(cuid())
  workingDayId    String
  roomNumber      Int
  optometristName String
  taskType        OptCallTaskType
  notes           String?
  status          OptCallStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  acknowledgedAt  DateTime?

  workingDay WorkingDay @relation(fields: [workingDayId], references: [id])
}

enum OptCallTaskType {
  POST_CHECK_SINGLE_STIM
  POST_CHECK_MULTI_STIM
  POST_CHECK_ZATA_24_2
  POST_CHECK_PRESSURES
  POST_CHECK_FUNDUS_PHOTOS
  POST_CHECK_CLINICAL_OCT
  POST_CHECK_CLINICAL_OPTOMAP
  DISPENSE_SINGLE_VISION
  DISPENSE_VARIFOCAL
}

enum OptCallStatus {
  PENDING
  ACKNOWLEDGED
}
